{
  "name": "snag.zip",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts & bun run css:watch",
    "dev:server": "bun run --watch src/index.ts",
    "css": "bunx @tailwindcss/cli -i src/styles.css -o public/styles.css --minify",
    "css:watch": "bunx @tailwindcss/cli -i src/styles.css -o public/styles.css --watch",
    "build": "bun run css",
    "start": "bun run src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@elysiajs/static": "^1.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "elysia": "^1.3",
    "fflate": "^0.8",
    "nanoid": "^5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@types/bun": "latest",
    "tailwindcss": "^4",
    "typescript": "^5.7"
  }
}
